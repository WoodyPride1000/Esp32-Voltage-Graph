// Google Apps Script コード

// このスクリプトがデータを書き込むスプレッドシートのIDを指定してください
// スプレッドシートのURLから取得できます (例: https://docs.google.com/spreadsheets/d/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/edit#gid=0 の 'XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX' の部分)
const SPREADSHEET_ID = "YOUR_SPREADSHEET_ID_HERE"; // <<< ここをあなたのスプレッドシートIDに置き換えてください

// ESP32からの簡易認証用シークレットキー。ESP32のコードと一致させてください
const EXPECTED_SECRET_KEY = "your_secret_key"; // <<< ESP32の GOOGLE_SHEET_API_SECRET と同じ値を設定

const SHEET_HEADERS = ["Timestamp", "V1", "V2", "V3", "V4"];

/**
 * HTTP POSTリクエストを処理する関数
 * ESP32がこのWebアプリにデータを送信すると、この関数が実行されます。
 * @param {object} e イベントオブジェクト (HTTP POSTリクエストの情報を含む)
 */
function doPost(e) {
  try {
    if (!e.postData || !e.postData.contents) {
      return ContentService.createTextOutput("No POST body").setMimeType(ContentService.MimeType.TEXT);
    }

    // リクエストボディからJSONデータを取得
    const jsonString = e.postData.contents;
    const data = JSON.parse(jsonString);

    // 簡易認証: シークレットはURLクエリでもヘッダーでもなくJSONボディ内で検証する。
    // GASの doPost(e) はカスタムHTTPヘッダーを取得できないため。
    if (!data.secret || data.secret !== EXPECTED_SECRET_KEY) {
      Logger.log("Authentication failed. Received: " + JSON.stringify(data));
      return ContentService.createTextOutput("Authentication Failed").setMimeType(ContentService.MimeType.TEXT);
    }

    // 必須フィールドの検証（欠落・型不正のまま appendRow に渡さない）
    if (typeof data.timestamp !== "number" ||
        typeof data.v1 !== "number" || typeof data.v2 !== "number" ||
        typeof data.v3 !== "number" || typeof data.v4 !== "number") {
      Logger.log("Invalid payload: " + jsonString);
      return ContentService.createTextOutput("Invalid payload").setMimeType(ContentService.MimeType.TEXT);
    }

    Logger.log("Received data: " + JSON.stringify(data));

    // スプレッドシートを開く
    const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getActiveSheet();

    // 初回書き込み時はヘッダー行を追加する
    if (sheet.getLastRow() === 0) {
      sheet.appendRow(SHEET_HEADERS);
    }

    // タイムスタンプを読み取り可能な日付形式に変換
    const date = new Date(data.timestamp * 1000); // JavaScriptのDateはミリ秒単位なので1000を乗算

    // スプレッドシートに新しい行を追加
    sheet.appendRow([
      date.toLocaleString(), // 日付と時刻
      data.v1,
      data.v2,
      data.v3,
      data.v4
    ]);

    // 成功レスポンスを返す
    return ContentService.createTextOutput("Data logged successfully").setMimeType(ContentService.MimeType.TEXT);

  } catch (error) {
    // エラー処理
    Logger.log("Error: " + error.toString());
    return ContentService.createTextOutput("Error logging data: " + error.toString()).setMimeType(ContentService.MimeType.TEXT);
  }
}

/**
 * デプロイ後の疎通確認用。ブラウザでWebアプリURLに直接アクセスした場合に応答する。
 */
function doGet(e) {
  return ContentService.createTextOutput("ESP32 receiver is running").setMimeType(ContentService.MimeType.TEXT);
}
